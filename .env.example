# Supabase (accounts) — get these from Supabase dashboard → Project Settings → API
# Add to .env.local for local dev AND to Vercel → Settings → Environment Variables for prod.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Project Settings → API → service_role). NEVER prefix with NEXT_PUBLIC.
# Used only by the account-delete route. Add to Vercel env (not exposed to the browser).
SUPABASE_SERVICE_ROLE_KEY=
